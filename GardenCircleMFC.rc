#include "resource.h"
#include "afxres.h"

IDD_GARDENCIRCLEMFC_DIALOG DIALOGEX 0, 0, 720, 430
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_APPWINDOW
CAPTION "Garden Circle Assignment"
FONT 9, "Malgun Gothic", 400, 0, 0x81
BEGIN
    CONTROL         "",IDC_CANVAS,"STATIC",SS_BLACKFRAME | SS_NOTIFY | WS_CHILD | WS_VISIBLE,10,10,545,390
    LTEXT           "Point radius",IDC_STATIC_RADIUS,570,20,95,12
    EDITTEXT        IDC_EDIT_RADIUS,570,35,60,14,ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Garden border",IDC_STATIC_BORDER,570,60,95,12
    EDITTEXT        IDC_EDIT_BORDER,570,75,60,14,ES_AUTOHSCROLL | ES_NUMBER
    PUSHBUTTON      "Reset",IDC_BUTTON_RESET,570,110,130,24
    PUSHBUTTON      "Random Move",IDC_BUTTON_RANDOM,570,140,130,24
    LTEXT           "Status: waiting for points",IDC_STATIC_STATUS,570,178,135,35,SS_LEFT
    LTEXT           "Click three points to draw one garden circle.\nDrag any point to redraw until release.\nExtra clicks after three points are ignored.\nThe garden interior is not filled.",IDC_STATIC_HELP,570,225,135,95,SS_LEFT
END
